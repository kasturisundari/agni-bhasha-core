॥ ॐ
   यन्त्रसङ्केत_जननम् (Machine Code Generator)
॥

अधिकार यन्त्रसङ्केत_जननम् {

    सूत्र सृज्_यन्त्रसङ्केत(व्याकरण_वृक्ष) {
        प्रदर्शय("   -> [यन्त्रसङ्केत_जननम्] AST वृक्षात् यन्त्रसङ्केतः निर्मीयते...")
        
        यन्त्र_सञ्चिका_नाम ← "उत्पादनम्.अग्नि_कोड"
        यन्त्रसङ्केतः ← "AGNI_MAGIC_BYTECODE_V1\n"
        
        प्रतिकृति (शाखा in व्याकरण_वृक्ष) {
            यदि (शाखा.प्रकार == "क्रिया_पद") {
                यन्त्रसङ्केतः ← यन्त्रसङ्केतः + "EXEC_DHATU " + शाखा.मूल्य + "\n"
            } अन्यथा {
                यन्त्रसङ्केतः ← यन्त्रसङ्केतः + "PUSH_KARMA " + शाखा.मूल्य + "\n"
            }
        }

        यन्त्रसङ्केतः ← यन्त्रसङ्केतः + "HALT\n"

        ॥ सञ्चिकायां लिख (Write to file) ॥
        लेखन(यन्त्र_सञ्चिका_नाम, यन्त्रसङ्केतः)

        √दा+ति·यन्त्र_सञ्चिका_नाम
    }
}
