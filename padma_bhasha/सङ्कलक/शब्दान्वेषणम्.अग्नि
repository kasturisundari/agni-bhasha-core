॥ ॐ
   शब्दान्वेषणम् (Lexical Analyzer)
॥

अधिकार शब्दान्वेषणम् {

    सूत्र धातु_विच्छेदन(मूल_कथनम) {
        प्रदर्शय("   -> [शब्दान्वेषणम्] कथनानां विच्छेदनं क्रियते...")
        
        ॥ १. रिक्तस्थानानि निष्कासय (Remove Whitespace) ॥
        शुद्ध_कथनम ← स्वच्छ(मूल_कथनम)

        ॥ २. धातु_प्रत्यय_विभाजनम् (Split Roots and Suffixes) ॥
        शब्दाः ← विभाजन(शुद्ध_कथनम, " ")

        अक्षर_सूचि ← नूतन_सूचि()
        
        प्रतिकृति (शब्द in शब्दाः) {
            यदि (शब्द.प्रारम्भ("√")) {
                अक्षर_सूचि.योजय("धातु: " + शब्द)
            } अन्यथा यदि (शब्द.प्रारम्भ("॥")) {
                अक्षर_सूचि.योजय("टिप्पणी")
            } अन्यथा {
                अक्षर_सूचि.योजय("सामान्य: " + शब्द)
            }
        }

        √दा+ति·अक्षर_सूचि
    }
}
