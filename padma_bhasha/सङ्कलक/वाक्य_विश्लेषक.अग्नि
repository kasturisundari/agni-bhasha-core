॥ ॐ
   अग्निभाषा_सङ्कलक 
   वाक्य_विश्लेषक ( )
॥

अधिकार व्याकरण_विश्लेषक {

    ॥ :    ॥
    सूत्र वर्तमान_लक्षण_प्राप्ति(लक्षणानि, वर्तमान_स्थान) {
        √सृज्+ति·दीर्घता ← √मा+ति·लक्षणानि
        यदि (वर्तमान_स्थान < दीर्घता) {
            √दा+ति·लक्षणानि[वर्तमान_स्थान]
        }
        अन्यथा {
            √दा+ति·["अन्त", "", ०]
        }
    }

    ॥ :    यदि    ॥
    सूत्र लक्षण_परीक्षण(लक्षणानि, वर्तमान_स्थान, अपेक्षित_प्रकार) {
        √सृज्+ति·लक्षण ← वर्तमान_लक्षण_प्राप्ति(लक्षणानि, वर्तमान_स्थान)
        √सृज्+ति·लक्षण_प्रकार ← लक्षण[०]
        
        यदि (लक्षण_प्रकार == अपेक्षित_प्रकार) {
            √दा+ति·वर्तमान_स्थान + १
        }
        अन्यथा {
            √दा+ति·वर्तमान_स्थान
        }
    }

    ॥     ॥
    सूत्र वाक्य_विश्लेषण(लक्षणानि, वर्तमान_स्थान) {
        √सृज्+ति·लक्षण ← वर्तमान_लक्षण_प्राप्ति(लक्षणानि, वर्तमान_स्थान)
        √सृज्+ति·लक्षण_प्रकार ← लक्षण[०]
        √सृज्+ति·लक्षण_मूल्य ← लक्षण[१]

        यदि (लक्षण_प्रकार == "धातु_उपसर्ग") {
            √सृज्+ति·चर_नाम ← "कल्पित_चर"
            √सृज्+ति·चर_मूल्य ← ["मूल्य", ४२]
            √सृज्+ति·ग्रन्थि ← नियुक्ति_ग्रन्थि(चर_नाम, चर_मूल्य)
            
            √दा+ति·[वर्तमान_स्थान + ६, ग्रन्थि]
        }
        अन्यथा {
            यदि (लक्षण_प्रकार == "सूत्र") {
                √सृज्+ति·सूत्र_नाम ← "कल्पित_सूत्र"
                √सृज्+ति·सूत्र_मापदण्डाः ← []
                √सृज्+ति·सूत्र_शरीर ← []
                √सृज्+ति·ग्रन्थि ← सूत्र_रचना_ग्रन्थि(सूत्र_नाम, सूत्र_मापदण्डाः, सूत्र_शरीर)
                
                √दा+ति·[वर्तमान_स्थान + ७, ग्रन्थि]
            }
            अन्यथा {
                √दा+ति·[वर्तमान_स्थान + १, ["अज्ञात_वाक्य"]]
            }
        }
    }

    ॥   :          ॥
    सूत्र योजना_विश्लेषण(लक्षणानि) {
        √सृज्+ति·वाक्यानि ← []
        √सृज्+ति·वर्तमान_स्थान ← ०
        √सृज्+ति·दीर्घता ← √मा+ति·लक्षणानि
        
        √चर्+मान·क→१००० :: {
            √सृज्+ति·लक्षण ← वर्तमान_लक्षण_प्राप्ति(लक्षणानि, वर्तमान_स्थान)
            यदि (लक्षण[०] == "अन्त") {
                √सृज्+ति·वर्तमान_स्थान ← दीर्घता
            }
            अन्यथा {
                यदि (वर्तमान_स्थान < दीर्घता) {
                    √सृज्+ति·विश्लेषण_परिणाम ← वाक्य_विश्लेषण(लक्षणानि, वर्तमान_स्थान)
                    
                    √सृज्+ति·वर्तमान_स्थान ← विश्लेषण_परिणाम[०]
                    √सृज्+ति·वाक्य_ग्रन्थि ← विश्लेषण_परिणाम[१]
                    
                    √युज्+ति·वाक्यानि·वाक्य_ग्रन्थि
                }
            }
        }
        
        √सृज्+ति·मूल_ग्रन्थि ← योजना_ग्रन्थि(वाक्यानि)
        √दा+ति·मूल_ग्रन्थि
    }

}
