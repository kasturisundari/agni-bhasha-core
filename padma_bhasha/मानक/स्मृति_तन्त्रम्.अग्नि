॥ ॐ
   स्मृति_तन्त्रम् (Direct Memory Access & Management)
   पद्म_मानक (Padma Standard Library)
॥

अधिकार स्मृति_तन्त्रम् {

    सूत्र स्मृति_आवन्टनम्(आकारः_बाइट्) {
        ॥ OS System Call: MALLOC / mmap ॥
        यन्त्र_आदेश: "SYS_MEM_ALLOC"
        
        प्रदर्शय("[स्मृति_तन्त्रम्] साक्षात् स्मृतेः आवन्टनं क्रियते (Direct RAM Allocation): " + आकारः_बाइट् + " Bytes")
        
        स्मृति_सङ्केतः ← यन्त्र_स्मृति_आवन्टन(आकारः_बाइट्)
        
        यदि (स्मृति_सङ्केतः == शून्यम्) {
            विफलता("स्मृति_अभावः (Out of Memory/RAM)")
        }

        √दा+ति·स्मृति_सङ्केतः
    }

    सूत्र स्मृति_मुक्तिः(स्मृति_सङ्केतः) {
        ॥ OS System Call: FREE / munmap ॥
        यन्त्र_आदेश: "SYS_MEM_FREE"
        
        प्रदर्शय("[स्मृति_तन्त्रम्] स्मृतिखण्डः मुक्तः क्रियते (Freeing RAM block): " + स्मृति_सङ्केतः)
        
        यन्त्र_स्मृति_मुक्ति(स्मृति_सङ्केतः)
        √दा+ति·"मुक्तम्"
    }

    सूत्र प्रत्यक्ष_पठनम्(स्मृति_सङ्केतः) {
        ॥ OS System Call: Read Pointer ॥
        यन्त्र_आदेश: "SYS_MEM_READ"
        √दा+ति·यन्त्र_पठन(स्मृति_सङ्केतः)
    }

    सूत्र प्रत्यक्ष_लेखनम्(स्मृति_सङ्केतः, दत्तांश) {
        ॥ OS System Call: Write to Pointer ॥
        यन्त्र_आदेश: "SYS_MEM_WRITE"
        यन्त्र_लेखन(स्मृति_सङ्केतः, दत्तांश)
        √दा+ति·"सफलम्"
    }
}
