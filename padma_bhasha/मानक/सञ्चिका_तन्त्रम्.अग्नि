॥ ॐ
   सञ्चिका_तन्त्रम् (File System I/O Operations)
   पद्म_मानक (Padma Standard Library)
॥

अधिकार सञ्चिका_तन्त्रम् {

    सूत्र पठनम्(सञ्चिका_मार्ग) {
        ॥ OS System Call: Read Bytes ॥
        यन्त्र_आदेश: "SYS_READ"
        
        प्रदर्शय("[सञ्चिका_तन्त्रम्] पठनम् क्रियते: " + सञ्चिका_मार्ग)
        √ज्ञा+ति·सञ्चिका_स्थिति
        
        यदि (सञ्चिका_स्थिति == शून्यम्) {
            विफलता("सञ्चिका न दृष्टा (File Not Found)")
        }

        दत्तांश ← यन्त्र_पठन(सञ्चिका_मार्ग)
        √दा+ति·दत्तांश
    }

    सूत्र लेखनम्(सञ्चिका_मार्ग, दत्तांश) {
        ॥ OS System Call: Write Bytes ॥
        यन्त्र_आदेश: "SYS_WRITE"
        
        प्रदर्शय("[सञ्चिका_तन्त्रम्] लेखनम् क्रियते: " + सञ्चिका_मार्ग)
        
        यन्त्र_लेखन(सञ्चिका_मार्ग, दत्तांश)
        √दा+ति·"सफलम्"
    }

    सूत्र पत्रागार_सर्जनम्(पत्रागार_मार्ग) {
        ॥ OS System Call: Make Directory ॥
        यन्त्र_आदेश: "SYS_MKDIR"
        
        प्रदर्शय("[सञ्चिका_तन्त्रम्] नूतन पत्रागार: " + पत्रागार_मार्ग)
        यन्त्र_पत्रागार(पत्रागार_मार्ग)
        √दा+ति·"सफलम्"
    }
}
