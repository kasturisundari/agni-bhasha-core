॥ ॐ
   आरोग्यमण्डल 
॥

आयात "../मानक/मण्डल_रूप.अग्नि"
आयात "../मानक/सङ्ग्रह_दत्तांश.अग्नि"

अधिकार आरोग्यमण्डल {

    सूत्र आरम्भ() {
        
        √सृज्+ति·दत्तांश ← सम्बन्ध_स्थापन("आरोग्य_दत्तांश.वेद")
        
        √सृज्+ति·वातायन ← वातायन_रचना("आरोग्यमण्डल", ८००, ६००)
        
        √सृज्+ति·नाम_क्षेत्र ← लेख्यस्थान_रचना("रोगी_नाम")
        √सृज्+ति·लक्षण_क्षेत्र ← लेख्यस्थान_रचना("लक्षण")
        
        √सृज्+ति·संरक्षण_बटन ← गुण्डिका_रचना("संरक्षण", "सङ्ग्रह_कार्य")
        
        √सृज्+ति·अङ्गानि ← [नाम_क्षेत्र, लक्षण_क्षेत्र, संरक्षण_बटन]
        प्रदर्शन(वातायन, अङ्गानि)
        
        √दा+ति·"आरम्भ_सफल"
    }

    सूत्र सङ्ग्रह_कार्य(नाम, लक्षण) {
        √सृज्+ति·दत्तांश ← सम्बन्ध_स्थापन("आरोग्य_दत्तांश.वेद")
        
        √सृज्+ति·प्रश्नोत्तर ← "प्रवेश_कुरु रोगी_नाम लक्षण मूल्य " + नाम + " " + लक्षण
        प्रश्न_निष्पादन(दत्तांश, प्रश्नोत्तर)
        
        √दा+ति·"रोगी_रक्षितः"
    }

}
