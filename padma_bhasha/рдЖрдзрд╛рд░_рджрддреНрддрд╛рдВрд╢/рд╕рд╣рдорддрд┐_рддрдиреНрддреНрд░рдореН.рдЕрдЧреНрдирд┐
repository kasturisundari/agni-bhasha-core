॥ ॐ
   सहमति_तन्त्रम् (Raft/Paxos Distributed Consensus Protocol)
   आधार_दत्तांश (Aadhaara Database Engine)
॥

आयात "../मानक/सम्पर्क_जाल.अग्नि"

अधिकार सहमति_तन्त्रम् {

    सूत्र नेतृत्व_चयनम्(यन्त्राणि_सूचि) {
        प्रदर्शय("[सहमति_तन्त्रम्] निर्वाचनं आरभ्यते (Starting Leader Election)...")
        
        मम_मतम् ← १
        सङ्गृहीत_मतानि ← १
        
        प्रतिकृति (यन्त्र in यन्त्राणि_सूचि) {
            प्रदर्शय("  -> मतयाचना (Requesting vote from): " + यन्त्र)
            अवस्था ← सम्पर्क_जाल.प्रेषणम्("VOTE_REQ", यन्त्र)
            
            यदि (अवस्था == "सम्मतम्") {
                सङ्गृहीत_मतानि ← सङ्गृहीत_मतानि + १
            }
        }

        बहुमतम् ← (यन्त्राणि_सूचि.सङ्ख्या() / २) + १
        
        यदि (सङ्गृहीत_मतानि >= बहुमतम्) {
            प्रदर्शय("  -> विजयः! अहम् नायकः अस्मि (I am the Leader!).")
            √दा+ति·"नायकः"
        } अन्यथा {
            प्रदर्शय("  -> पराजयः! अहम् अनुयायी अस्मि (I am a Follower).")
            √दा+ति·"अनुयायी"
        }
    }

    सूत्र हृदय_स्पन्दनम्(अनुयायिनः) {
        प्रदर्शय("[सहमति_तन्त्रम्] हृदय_स्पन्दनं प्रेष्यते (Sending Heartbeats)...")
        
        प्रतिकृति (अनुयायी in अनुयायिनः) {
            सम्पर्क_जाल.प्रेषणम्("HEARTBEAT_ALIVE", अनुयायी)
        }
    }

    सूत्र प्रतिकृति_प्रेषणम्(दत्तांश, अनुयायिनः) {
        प्रदर्शय("[सहमति_तन्त्रम्] दत्तांशस्य प्रतिकृतिः क्रियते (Replicating Log Entry)...")
        
        सम्मत_यन्त्राणि ← ०
        प्रतिकृति (अनुयायी in अनुयायिनः) {
            अवस्था ← सम्पर्क_जाल.प्रेषणम्("APPEND_ENTRY:" + दत्तांश, अनुयायी)
            यदि (अवस्था == "सफलम्") {
                सम्मत_यन्त्राणि ← सम्मत_यन्त्राणि + १
            }
        }
        
        बहुमतम् ← (अनुयायिनः.सङ्ख्या() / २) + १
        यदि (सम्मत_यन्त्राणि >= बहुमतम्) {
            प्रदर्शय("  -> सर्वसम्मतिः प्राप्ता! दत्तांशः सुरक्षितः (Consensus Reached! Data committed).")
            √दा+ति·"सुरक्षितम्"
        }
    }
}
