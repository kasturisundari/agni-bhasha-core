॥ ॐ
   अग्निभाषा_सङ्कलक 
   यन्त्रसङ्केत_निर्माता ( )
॥

अधिकार सङ्कलक_अधिकार {

    ॥    ॥
    सूत्र शीर्षक_रचना() {
        √सृज्+ति·शीर्षक ← "भाग_दत्तांश
"
        √सृज्+ति·शीर्षक ← शीर्षक + "    सन्देश_लेखन \"ॐ अग्निभाषा_मूल_यन्त्रसङ्केत ॐ\", १०
"
        √सृज्+ति·शीर्षक ← शीर्षक + "भाग_सङ्केत
"
        √सृज्+ति·शीर्षक ← शीर्षक + "    सार्वभौम_आरम्भ
"
        √सृज्+ति·शीर्षक ← शीर्षक + "आरम्भ:
"
        
        √दा+ति·शीर्षक
    }

    ॥    ॥
    सूत्र अन्त_रचना() {
        √सृज्+ति·अन्त_भाग ← "    चालय_प्रथम_६०
"
        √सृज्+ति·अन्त_भाग ← अन्त_भाग + "    चालय_द्वितीय_०
"
        √सृज्+ति·अन्त_भाग ← अन्त_भाग + "    यन्त्र_आह्वान
"
        
        √दा+ति·अन्त_भाग
    }

    ॥        ॥
    सूत्र वाक्य_सङ्कलन(ग्रन्थि) {
        √सृज्+ति·ग्रन्थि_प्रकार ← ग्रन्थि[०]
        √सृज्+ति·यन्त्र_सङ्केत ← ""

        यदि (ग्रन्थि_प्रकार == "नियुक्ति") {
            √सृज्+ति·चर_नाम ← ग्रन्थि[१]
            √सृज्+ति·चर_मूल्य_ग्रन्थि ← ग्रन्थि[२]
            
            यदि (चर_मूल्य_ग्रन्थि[०] == "मूल्य") {
                √सृज्+ति·मूल्य ← चर_मूल्य_ग्रन्थि[१]
                यन्त्र_सङ्केत ← "    चालय_प्रथम_" + मूल्य + "
"
            }
        }
        अन्यथा {
            यदि (ग्रन्थि_प्रकार == "प्रत्यावर्तन") {
                यन्त्र_सङ्केत ← "    ; प्रत्यावर्तन_निष्पादितम्
"
            }
        }
        
        √दा+ति·यन्त्र_सङ्केत
    }

    ॥   :    `.`  ॥
    सूत्र यन्त्र_सङ्केत_निर्माण(मूल_ग्रन्थि) {
        √सृज्+ति·अन्तिम_सङ्केत ← शीर्षक_रचना()
        
        यदि (मूल_ग्रन्थि[०] == "योजना") {
            √सृज्+ति·वाक्यानि ← मूल_ग्रन्थि[१]
            √सृज्+ति·दीर्घता ← √मा+ति·वाक्यानि
            
            √चर्+मान·क→दीर्घता :: {
                √सृज्+ति·वाक्य_ग्रन्थि ← वाक्यानि[क]
                √सृज्+ति·वाक्य_सङ्केत ← वाक्य_सङ्कलन(वाक्य_ग्रन्थि)
                
                अन्तिम_सङ्केत ← अन्तिम_सङ्केत + वाक्य_सङ्केत
            }
        }
        
        अन्तिम_सङ्केत ← अन्तिम_सङ्केत + अन्त_रचना()
        
        √दा+ति·अन्तिम_सङ्केत
    }

}
