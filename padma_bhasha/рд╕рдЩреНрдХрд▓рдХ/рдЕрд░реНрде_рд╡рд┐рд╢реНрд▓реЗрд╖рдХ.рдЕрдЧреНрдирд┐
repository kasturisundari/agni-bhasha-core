॥ ॐ
   अग्निभाषा_सङ्कलक 
   अर्थ_विश्लेषक ( )
॥

अधिकार व्याकरण_अधिकार {

    ॥     ॥
    सूत्र अधिकार_क्षेत्र_आरम्भ {
        √सृज्+ति·अधिकार_क्षेत्र ← []
        √दा+ति·अधिकार_क्षेत्र
    }

    ॥      ॥
    सूत्र प्रकार_पञ्जीकरण(नाम, प्रकार_शब्द, अधिकार_क्षेत्र) {
        √सृज्+ति·प्रवेश ← [नाम, प्रकार_शब्द]
        √युज्+ति·अधिकार_क्षेत्र·प्रवेश
        √दा+ति·अधिकार_क्षेत्र
    }

    ॥    ॥
    सूत्र प्रकार_अन्वेषण(नाम, अधिकार_क्षेत्र) {
        √सृज्+ति·दीर्घता ← √मा+ति·अधिकार_क्षेत्र
        √सृज्+ति·प्राप्त_प्रकार ← "अज्ञात"
        
        √चर्+मान·क→दीर्घता :: {
            √सृज्+ति·प्रवेश ← अधिकार_क्षेत्र[क]
            यदि (प्रवेश[०] == नाम) {
                √सृज्+ति·प्राप्त_प्रकार ← प्रवेश[१]
            }
        }
        
        √दा+ति·प्राप्त_प्रकार
    }

    ॥      ॥
    सूत्र ग्रन्थि_परीक्षण(ग्रन्थि, अधिकार_क्षेत्र) {
        √सृज्+ति·ग्रन्थि_प्रकार ← ग्रन्थि[०]

        यदि (ग्रन्थि_प्रकार == "नियुक्ति") {
            √सृज्+ति·चर_नाम ← ग्रन्थि[१]
            √सृज्+ति·चर_मूल्य ← ग्रन्थि[२]
            
            √सृज्+ति·मूल्य_प्रकार ← "किञ्चित्"
            यदि (चर_मूल्य[०] == "सङ्ख्या") {
                √सृज्+ति·मूल्य_प्रकार ← "पूर्णाङ्क" 
            }
            
            √सृज्+ति·नूतन_अधिकार_क्षेत्र ← प्रकार_पञ्जीकरण(चर_नाम, मूल्य_प्रकार, अधिकार_क्षेत्र)
            √दा+ति·नूतन_अधिकार_क्षेत्र
        }
        अन्यथा {
            यदि (ग्रन्थि_प्रकार == "द्विगुण") {
                √सृज्+ति·वाम ← ग्रन्थि[१]
                √सृज्+ति·कारक ← ग्रन्थि[२]
                √सृज्+ति·दक्षिण ← ग्रन्थि[३]
                
                √दा+ति·अधिकार_क्षेत्र
            }
            अन्यथा {
                √दा+ति·अधिकार_क्षेत्र
            }
        }
    }

    ॥      ॥
    सूत्र योजना_परीक्षण(मूल_ग्रन्थि) {
        √सृज्+ति·अधिकार_क्षेत्र ← अधिकार_क्षेत्र_आरम्भ()
        
        यदि (मूल_ग्रन्थि[०] == "योजना") {
            √सृज्+ति·वाक्यानि ← मूल_ग्रन्थि[१]
            √सृज्+ति·दीर्घता ← √मा+ति·वाक्यानि
            
            √चर्+मान·क→दीर्घता :: {
                √सृज्+ति·वाक्य_ग्रन्थि ← वाक्यानि[क]
                √सृज्+ति·अधिकार_क्षेत्र ← ग्रन्थि_परीक्षण(वाक्य_ग्रन्थि, अधिकार_क्षेत्र)
            }
        }
        
        √दा+ति·"परीक्षण_सफल"
    }

}
