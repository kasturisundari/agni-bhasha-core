॥ ॐ
   वृक्ष_अन्वेषणम् (Advanced B-Tree Algorithms)
   आधार_दत्तांश (Aadhaara Database Engine)
॥

आयात "../मानक/सञ्चिका_तन्त्रम्.अग्नि"
आयात "../मानक/गणित_शास्त्रम्.अग्नि"
आयात "../मानक/स्मृति_तन्त्रम्.अग्नि"

अधिकार वृक्ष_अन्वेषणम् {

    सूत्र नोड_विभाजनम्(पूर्ण_शाखा) {
        प्रदर्शय("[वृक्ष_अन्वेषणम्] शाखा पूर्णः अस्ति। विभाजनं क्रियते (Splitting full node)...")
        
        मध्य_कुञ्जी ← पूर्ण_शाखा.मध्यम_अंश()
        वाम_शाखा ← नूतन_शाखा(पूर्ण_शाखा.वाम_भाग())
        दक्षिण_शाखा ← नूतन_शाखा(पूर्ण_शाखा.दक्षिण_भाग())

        ॥ Update pointers in parent node ॥
        पूर्ण_शाखा.जनक.योजय(मध्य_कुञ्जी, वाम_शाखा, दक्षिण_शाखा)
        
        √दा+ति·"विभाजन_सफलम्"
    }

    सूत्र सन्तुलनम्(वृक्ष_मूल) {
        प्रदर्शय("[वृक्ष_अन्वेषणम्] वृक्षस्य सन्तुलनं क्रियते (Balancing B-Tree)...")
        ॥ B-Tree Rebalancing Algorithm to maintain O(log N) depth ॥
        
        यदि (वृक्ष_मूल.असन्तुलित()) {
            वृक्ष_मूल.भ्रमण()
            प्रदर्शय("  -> वृक्षः इदानीं सन्तुलितः अस्ति (Tree is now balanced).")
        }
        
        √दा+ति·वृक्ष_मूल
    }

    सूत्र अन्वेषणम्(कुञ्जी, वृक्ष_मूल) {
        प्रदर्शय("[वृक्ष_अन्वेषणम्] कुञ्जी अन्विष्यते (Binary Search on B-Tree): " + कुञ्जी)
        हैश_कुञ्जी ← गणित_शास्त्रम्.हैश_निर्माणम्(कुञ्जी)
        
        प्रतिकृति (स्तर in वृक्ष_मूल) {
            यदि (कुञ्जी == स्तर.कुञ्जी) {
                √दा+ति·स्तर.दत्तांश
            } अन्यथा यदि (कुञ्जी < स्तर.कुञ्जी) {
                वृक्ष_मूल ← स्तर.वाम_शाखा
            } अन्यथा {
                वृक्ष_मूल ← स्तर.दक्षिण_शाखा
            }
        }
        √दा+ति·"न_दृष्टम्"
    }
}
