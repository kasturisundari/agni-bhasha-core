॥ ॐ
   आधार_दत्तांश
   प्रश्नानां_विश्लेषणम् (Paninian Query NLP Parser)
॥

अधिकार प्रश्न_विश्लेषक {

    ॥ पाणिनीय_व्याकरण_आधारितं वाक्यविश्लेषणम् ॥
    सूत्र धातु_विश्लेषण(वाक्य) {
        ॥ Extracts Dhatu (Verb/Action) and Karma (Object) ॥
        √सृज्+ति·क्रिया_धातु ← ""
        √सृज्+ति·कर्म_पद ← ""
        √सृज्+ति·अतिरिक्त_दत्तांश ← ""
        
        यदि (वाक्य == "प्रवेशं कुरु") {
            क्रिया_धातु ← "प्रवेश" ॥ Match Insert Verb ॥
        } अन्यथा यदि (वाक्य == "अन्वेषणं कुरु") {
            क्रिया_धातु ← "अन्वेषण" ॥ Match Select/Search Verb ॥
        } अन्यथा {
            क्रिया_धातु ← "अज्ञात"
        }
        
        √दा+ति·[क्रिया_धातु, कर्म_पद, अतिरिक्त_दत्तांश]
    }

    ॥ मुख्य_विश्लेषण_सूत्रम् ॥
    सूत्र प्रश्न_विच्छेदन(प्रश्न) {
        ॥ Splits input query by space delimiter ॥
        √सृज्+ति·विभक्त_पद ← प्रश्न
        √सृज्+ति·क्रिया_पद ← विभक्त_पद[०]
        √सृज्+ति·सङ्ग्रह_नाम ← विभक्त_पद[१]
        √सृज्+ति·अभिलेख_दत्तांश ← विभक्त_पद[२]
        
        √दा+ति·[क्रिया_पद, सङ्ग्रह_नाम, अभिलेख_दत्तांश]
    }

}
